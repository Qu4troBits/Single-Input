<?php

declare(strict_types=1);

namespace Tests\Unit\Application\Reports\Handlers;

use App\Application\Reports\Data\GenerateDreData;
use App\Application\Reports\Handlers\GenerateDreHandler;
use App\Domain\Reports\Dre;
use App\Domain\Reports\DreGenerator;
use App\Domain\Reports\ValueObjects\DrePeriod;
use PHPUnit\Framework\TestCase;
use Prophecy\PhpUnit\ProphecyTrait;
use Prophecy\Prophecy\ObjectProphecy;

final class GenerateDreHandlerTest extends TestCase
{
    use ProphecyTrait;

    private ObjectProphecy $dreGenerator;
    private GenerateDreHandler $handler;

    protected function setUp(): void
    {
        parent::setUp();
        
        $this->dreGenerator = $this->prophesize(DreGenerator::class);
        $this->handler = new GenerateDreHandler($this->dreGenerator->reveal());
    }

    public function test_handle_monthly_dre(): void
    {
        $data = new GenerateDreData(
            periodType: 'monthly',
            yearMonth: '2024-01',
            categoryId: null,
            scenario: 'base',
        );

        $period = DrePeriod::createMonthly('2024-01');
        
        $dre = $this->prophesize(Dre::class);
        $dre->getPeriod()->willReturn($period);
        $dre->getTitle()->willReturn('Demonstrativo de Resultados do Exercício - janeiro/2024');
        $dre->getCategoryId()->willReturn(null);
        $dre->getScenario()->willReturn('base');
        
        $this->dreGenerator->generate($period, null, 'base')
            ->willReturn($dre->reveal())
            ->shouldBeCalled();
        
        $this->dreGenerator->generateDreTitle($period, null, 'base')
            ->willReturn('Demonstrativo de Resultados do Exercício - janeiro/2024')
            ->shouldBeCalled();

        $result = $this->handler->handle($data);

        $this->assertInstanceOf(Dre::class, $result);
        $this->assertEquals('Demonstrativo de Resultados do Exercício - janeiro/2024', $result->getTitle());
        $this->assertNull($result->getCategoryId());
        $this->assertEquals('base', $result->getScenario());
    }

    public function test_handle_quarterly_dre(): void
    {
        $data = new GenerateDreData(
            periodType: 'quarterly',
            year: '2024',
            quarter: 1,
            categoryId: null,
            scenario: 'base',
        );

        $period = DrePeriod::createQuarterly('2024', 1);
        
        $dre = $this->prophesize(Dre::class);
        $dre->getPeriod()->willReturn($period);
        $dre->getTitle()->willReturn('Demonstrativo de Resultados do Exercício - 1º Trimestre 2024');
        $dre->getCategoryId()->willReturn(null);
        $dre->getScenario()->willReturn('base');
        
        $this->dreGenerator->generate($period, null, 'base')
            ->willReturn($dre->reveal())
            ->shouldBeCalled();
        
        $this->dreGenerator->generateDreTitle($period, null, 'base')
            ->willReturn('Demonstrativo de Resultados do Exercício - 1º Trimestre 2024')
            ->shouldBeCalled();

        $result = $this->handler->handle($data);

        $this->assertInstanceOf(Dre::class, $result);
        $this->assertEquals('Demonstrativo de Resultados do Exercício - 1º Trimestre 2024', $result->getTitle());
        $this->assertNull($result->getCategoryId());
        $this->assertEquals('base', $result->getScenario());
    }

    public function test_handle_yearly_dre(): void
    {
        $data = new GenerateDreData(
            periodType: 'yearly',
            year: '2024',
            categoryId: null,
            scenario: 'base',
        );

        $period = DrePeriod::createYearly('2024');
        
        $dre = $this->prophesize(Dre::class);
        $dre->getPeriod()->willReturn($period);
        $dre->getTitle()->willReturn('Demonstrativo de Resultados do Exercício - Ano 2024');
        $dre->getCategoryId()->willReturn(null);
        $dre->getScenario()->willReturn('base');
        
        $this->dreGenerator->generate($period, null, 'base')
            ->willReturn($dre->reveal())
            ->shouldBeCalled();
        
        $this->dreGenerator->generateDreTitle($period, null, 'base')
            ->willReturn('Demonstrativo de Resultados do Exercício - Ano 2024')
            ->shouldBeCalled();

        $result = $this->handler->handle($data);

        $this->assertInstanceOf(Dre::class, $result);
        $this->assertEquals('Demonstrativo de Resultados do Exercício - Ano 2024', $result->getTitle());
